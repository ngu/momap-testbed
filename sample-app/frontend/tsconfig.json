{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@mareano-frontend/*": ["../../../mareano-frontend/src/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react",
    "jsxFactory": "React.createElement",
    "jsxFragmentFactory": "React.Fragment"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.mjs"]
}
